### OpenTelemetry Node.js Example - REST Client Tests
### Start server: npm run start:otel

@baseUrl = http://localhost:3001

### ===========================================
### Health Check
### ===========================================

# @name healthCheck
GET {{baseUrl}}/health

### ===========================================
### Orders
### ===========================================

# @name createOrder
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "total": 49.99,
  "currency": "usd",
  "items": [
    { "name": "Widget", "price": 29.99 },
    { "name": "Gadget", "price": 20.00 }
  ]
}

###

# @name createOrderMinimal
# Minimal order - uses defaults
POST {{baseUrl}}/orders
Content-Type: application/json

{}

###

# @name getOrder
# Replace with actual order ID from createOrder response
GET {{baseUrl}}/orders/ord_123456_abc123

###

# @name getOrderDynamic
# Uses order ID from previous createOrder response
GET {{baseUrl}}/orders/{{createOrder.response.body.orderId}}

### ===========================================
### Batch Processing
### ===========================================

# @name batchProcess
POST {{baseUrl}}/batch
Content-Type: application/json

{
  "items": [
    { "id": 1, "data": "first item" },
    { "id": 2, "data": "second item" },
    { "id": 3, "data": "third item" },
    { "id": 4, "data": "fourth item" },
    { "id": 5, "data": "fifth item" }
  ]
}

###

# @name batchProcessLarge
# Larger batch to see batch.size attribute in spans
POST {{baseUrl}}/batch
Content-Type: application/json

{
  "items": [
    { "id": 1 }, { "id": 2 }, { "id": 3 }, { "id": 4 }, { "id": 5 },
    { "id": 6 }, { "id": 7 }, { "id": 8 }, { "id": 9 }, { "id": 10 }
  ]
}

### ===========================================
### Latency & Performance
### ===========================================

# @name slowOperation
# Simulates a 500ms slow operation - check http.server.request.duration metric
GET {{baseUrl}}/slow

### ===========================================
### Error Handling
### ===========================================

# @name simulateError
# Triggers error recording in spans and metrics
GET {{baseUrl}}/error

###

# @name notFound
# 404 error - check http.server.request.duration metric filtered by status code
GET {{baseUrl}}/orders/nonexistent_order_id

### ===========================================
### Nested Spans
### ===========================================

# @name nestedSpans
# Demonstrates parent-child span relationships
GET {{baseUrl}}/nested

### ===========================================
### Load Testing (run multiple times)
### ===========================================

# @name loadTestOrders
# Run this multiple times to generate traffic metrics
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "total": {{$randomInt 10 500}},
  "items": [
    { "name": "Random Item", "price": {{$randomInt 5 100}} }
  ]
}

### ===========================================
### All Endpoints Quick Test
### ===========================================

# Run these in sequence to test all functionality:
# 1. Health check
# 2. Create order
# 3. Get order
# 4. Batch process
# 5. Slow operation
# 6. Nested spans
# 7. Error simulation
